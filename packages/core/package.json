{
  "name": "@wind-coms/governflow-core",
  "version": "0.1.0",
  "description": "Protocol-agnostic governance kernel for GovernFlow — constraint DSL compiler, policy engine, COW sandbox, perception & delivery pipeline.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js"
    },
    "./di": {
      "types": "./dist/di/container.d.ts",
      "import": "./dist/di/container.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "governflow",
    "governance",
    "constraint",
    "rego",
    "opa",
    "policy-engine",
    "sandbox",
    "ast",
    "pipeline",
    "shapley",
    "canary"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sole03/mcp-rule-engine.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/sole03/mcp-rule-engine/issues"
  },
  "homepage": "https://github.com/sole03/mcp-rule-engine/tree/main/packages/core"
}