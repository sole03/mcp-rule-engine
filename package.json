{
  "name": "governflow",
  "version": "1.0.0-alpha.2",
  "description": "GovernFlow — AI-native code governance pipeline. Assemble, don't build.",
  "type": "module",
  "main": "dist/transport/index.js",
  "scripts": {
    "build": "tsc",
    "postinstall": "npx prisma generate",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "pretest": "npm run build",
    "test": "vitest run --no-cache",
    "test:watch": "vitest",
    "license:check": "node scripts/check-license.js",
    "license:fix": "node scripts/check-license.js",
    "bench": "npx tsx benchmarks/intent-recognizer.bench.ts && npx tsx benchmarks/graph-traverser.bench.ts",
    "start:http": "node dist/transport/http-server.js",
    "build:core": "cd packages/core && npx tsc",
    "build:all": "npm run build && npm run build:core"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^5.22.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.10.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "author": "MCP Rule Engine Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sole03/governflow.git"
  },
  "bugs": {
    "url": "https://github.com/sole03/governflow/issues"
  },
  "homepage": "https://github.com/sole03/governflow#readme",
  "bin": {
    "mcp-cognition-engine": "dist/transport/cli.js"
  },
  "files": [
    "dist",
    "prisma/schema.prisma",
    "README.md",
    "docs/"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cognition",
    "graph",
    "ast",
    "ai-agent"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "prisma": "^5.22.0"
  },
  "peerDependenciesMeta": {
    "prisma": {
      "optional": true
    }
  },
  "workspaces": [
    "packages/*"
  ]
}
