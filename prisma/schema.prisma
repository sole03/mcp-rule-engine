generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Rule {
  id              String   @id @default(uuid())
  projectId       String?
  scope           String   @default("project")
  priority        Float    @default(1.0)
  type            String
  pattern         String
  suggestion      String
  language        String   @default("typescript")
  fileExtensions  String?
  tags            String?
  confidence      String   @default("medium")
  source          String   @default("auto")
  category        String?
  status          String   @default("active")
  matchCount      Int      @default(0)
  hitCount          Int      @default(0)
  falsePositiveCount Int      @default(0)
  adoptedCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastUsedAt      DateTime?
  // Rule lifecycle immune fields: cold-start buffer (immunityUntil), cold storage (archivedAt), auto-renew (expiresAt)
  immunityUntil   DateTime?
  archivedAt      DateTime?
  expiresAt       DateTime?
  renewCount      Int         @default(0)
  // Phase 3: shadow mode (null=activated, future date=shadow period)
  shadowUntil     DateTime?
  diffLogs        DiffLog[]
  conflictA       ConflictRecord[] @relation("conflictRuleA")
  conflictB       ConflictRecord[] @relation("conflictRuleB")
  versions        RuleVersion[]
  shadowLogs      ShadowLog[]
  policyVariants    PolicyVariant[]

  @@index([archivedAt])
  @@index([shadowUntil])
}

model DiffLog {
  id             String   @id @default(uuid())
  ruleId         String?
  filePath       String
  fileExtension  String
  language       String
  projectId      String?
  originalHash   String
  modifiedHash   String
  diffContent    String
  astStatus      String?
  diffType       String
  operations     String?
  createdAt      DateTime @default(now())
  rule           Rule?    @relation(fields: [ruleId], references: [id])
}

model ConflictRecord {
  id          String    @id @default(uuid())
  ruleAId     String
  ruleBId     String
  scopeKey    String
  resolution  String?
  batchChoice String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  ruleA       Rule      @relation("conflictRuleA", fields: [ruleAId], references: [id])
  ruleB       Rule      @relation("conflictRuleB", fields: [ruleBId], references: [id])
}

model MetricEvent {
  id          String   @id @default(uuid())
  eventType   String
  properties  String?
  createdAt   DateTime @default(now())
}

model AppConfig {
  id    String @id @default("default")
  mode  String @default("silent")
  data  String?
}
model RuleVersion {
  id         String   @id @default(uuid())
  ruleId     String
  pattern    String
  suggestion String?
  editedBy   String?
  createdAt  DateTime @default(now())

  rule       Rule     @relation(fields: [ruleId], references: [id])
}

// ── Proposal Governance (P0) ──────────────────────────────
// Injection approval workflow: PENDING → APPROVED | REJECTED | EXPIRED
model Proposal {
  id          String   @id @default(cuid())
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED | EXPIRED | OVERRIDDEN
  contextHash String
  toolName    String
  payload     String   // JSON
  nodeIds     String   // JSON array of node IDs
  proposedBy  String?
  reviewedBy  String?
  reviewNote  String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  approvalRequests ApprovalRequest[]

  @@unique([contextHash, status]) // only one PENDING per contextHash
  @@index([status])
  @@index([expiresAt])
}


// ── Approval Workflow (#16) ─────────────────────────────
// Multi-stage approval with escalation, delegation, webhooks.
// Stages: PENDING → PENDING_REVIEW → APPROVED | REJECTED | ESCALATED | EXPIRED | CANCELLED
model ApprovalRequest {
  id          String    @id @default(cuid())
  proposalId  String
  stage       String    @default("PENDING")
  contextHash String
  toolName    String
  payload     String?
  configJson  String    // JSON — ApprovalConfig
  votesJson   String    // JSON — ReviewerVote[]
  assignedTo  String?
  expiresAt   DateTime
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  proposal    Proposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([stage])
  @@index([assignedTo])
  @@index([expiresAt])
}

// ── Cognition Graph (Phase 2+) ─────────────────────────────
// Independent from legacy Rule engine. Do NOT modify existing models.

/// Cognitive node: represents an intent, constraint, heuristic, or pattern
/// in the cognition graph. Payload stores structured data only (AST JSON, DSL),
/// NEVER natural language. Uses String for JSON fields (SQLite limitation).
model CognitionNode {
  id               String          @id @default(cuid())
  type             String          // INTENT | CONSTRAINT | HEURISTIC | PATTERN
  semanticHash     String          @unique
  abstractionLevel Int             @default(0)
  payload          String          // JSON — structured AST templates / constraint expressions
  metadata         String?         // JSON — optional metadata (source diffId, etc.)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  outgoingEdges    CognitionEdge[] @relation("edgeSource")
  incomingEdges    CognitionEdge[] @relation("edgeTarget")
  astTemplate      AstTemplate?

  @@index([abstractionLevel])
  @@index([type])
}

/// Semantic edge connecting two cognition nodes.
/// Each (sourceId, targetId, relation) triple is unique.
/// relation values: CAUSES | PRECEDES | MUTEX | GENERALIZES | REFINES
model CognitionEdge {
  id        String         @id @default(cuid())
  sourceId  String
  targetId  String
  relation  String         // CAUSES | PRECEDES | MUTEX | GENERALIZES | REFINES
  weight    Float          @default(1.0)
  metadata  String?        // JSON — optional edge metadata
  createdAt DateTime       @default(now())

  source    CognitionNode  @relation("edgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target    CognitionNode  @relation("edgeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, relation])
  @@index([sourceId])
  @@index([targetId])
  @@index([relation])
}

/// Executable AST template linked to a cognition node.
/// Stores DSL/JSON patterns for AST-level validation or transformation.
/// NEVER stores natural language suggestions.
model AstTemplate {
  id               String         @id @default(cuid())
  nodeId           String         @unique
  language         String
  templateDsl      String
  validationSchema String?        // JSON — schema for validating templateDsl
  createdAt        DateTime       @default(now())

  node             CognitionNode  @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}


// A/B 策略变体 — Dimension 1.2
model PolicyVariant {
  id            String   @id @default(uuid())
  basePolicyId  String
  variant       String   // "A" | "B"
  overrides     String   // JSON — 覆盖的策略参数
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  rule          Rule     @relation(fields: [basePolicyId], references: [id], onDelete: Cascade)

  @@index([basePolicyId])
  @@index([variant])
}


// A/B 策略变体 — Dimension 1.2
// Shadow Mode Log (Phase 3.1 — mandatory shadow mode tracking)
model ShadowLog {
  id          String   @id @default(uuid())
  ruleId      String
  filePath    String
  matchedAt   DateTime @default(now())
  wouldBlock  Boolean  @default(false)
  rule        Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([matchedAt])
}